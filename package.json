{
	"name": "shoot",
	"version": "1.0.0",
	"description": "Activitypub federated instant messaging server",
	"license": "AGPL-3.0-or-later",
	"author": "MaddyUnderStars",
	"main": "dist/src/bootstrap.js",
	"scripts": {
		"start": "node --enable-source-maps dist/src/bootstrap.js",
		"start:http": "node --enable-source-maps dist/src/http/bootstrap.js",
		"start:gateway": "node --enable-source-maps dist/src/gateway/bootstrap.js",
		"start:media": "node --enable-source-maps dist/src/media/bootstrap.js",
		"start:push": "node --enable-source-maps dist/src/push/worker.js",
		"start:inbound_queue": "node --enable-source-maps dist/src/receiver/index.js",
		"cli": "node --enable-source-maps dist/src/cli/index.js",
		"build": "tsc",
		"prepare": "husky || true",
		"openapi": "node --enable-source-maps dist/src/scripts/openapi.js",
		"config": "node --enable-source-maps dist/src/scripts/configSchema.js",
		"test": "vitest",
		"fmt": "oxfmt",
		"lint": "oxlint",
		"postinstall": "patch-package"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "^8.4.0",
		"@aws-sdk/client-s3": "^3.717.0",
		"@aws-sdk/s3-request-presigner": "^3.717.0",
		"activitypub-types": "github:spacebarchat/activitypub-types#dist",
		"bcrypt": "^6.0.0",
		"body-parser": "^2.2.0",
		"bufferutil": "^4.1.0",
		"bullmq": "^5.34.4",
		"config": "^4.0.0",
		"cors": "^2.8.5",
		"domutils": "^3.2.2",
		"dotenv": "^17.2.3",
		"express": "^4.21.2",
		"express-rate-limit": "^7.5.0",
		"htmlparser2": "^10.0.0",
		"jsonwebtoken": "^9.0.2",
		"morgan": "^1.10.1",
		"patch-package": "^8.0.1",
		"rabbitmq-stream-js-client": "^1.0.0",
		"ts-deepmerge": "^7.0.2",
		"typeorm": "^0.3.27",
		"typeorm-cursor-pagination": "^0.10.1",
		"uuid": "^11.0.3",
		"web-push": "^3.6.7",
		"ws": "^8.18.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@swc/core": "^1.15.8",
		"@testcontainers/postgresql": "^11.11.0",
		"@types/bcrypt": "^5.0.2",
		"@types/config": "^3.3.3",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/morgan": "^1.9.9",
		"@types/node": "^22.10.2",
		"@types/pg": "^8.11.6",
		"@types/sinon": "^17.0.3",
		"@types/supertest": "^6.0.2",
		"@types/web-push": "^3.6.4",
		"@types/ws": "^8.5.13",
		"@vitest/coverage-v8": "^4.0.16",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.0",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"oxlint-tsgolint": "^0.22.1",
		"pg": "^8.16.3",
		"supertest": "^7.2.2",
		"testcontainers": "^11.11.0",
		"typescript": "^6.0.2",
		"unplugin-swc": "^1.5.9",
		"vitest": "^4.0.16"
	},
	"lint-staged": {
		"*.{ts,js,md,tsx,jsx,css}": "oxlint",
		"*": "oxfmt"
	}
}
