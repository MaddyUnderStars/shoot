{
	"include": ["./src/**/*", "./test/**/*"],
	"compilerOptions": {
		"incremental": true,
		"target": "ES2022",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"lib": ["ESNext", "ES2024.Object"],
		"module": "nodenext",
		"types": [],
		"resolveJsonModule": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": ".",
		"importHelpers": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"strictPropertyInitialization": false,
		"noImplicitThis": true,
		"alwaysStrict": true,
		"skipLibCheck": true
	}
}
